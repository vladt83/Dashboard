# Copy this file to `.env` (for local dev) and fill in the values.
# For production, set these in the Railway project's Variables tab.

# MySQL connection string. From Railway:
#   Open your MySQL service → Variables → click MYSQL_PUBLIC_URL → Copy value
# Example: mysql://root:abc123@roundhouse.proxy.rlwy.net:12345/railway
DATABASE_URL=

# Session signing secret. Must be long, random, and kept private.
# Generate with:  openssl rand -hex 48
JWT_SECRET=

# Dev-only. Railway sets PORT automatically in production.
PORT=3000
