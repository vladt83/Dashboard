# Environment variables — copy this file to .env for local dev, or set
# these in Vercel's project settings for production.
#
# Local dev: only DATABASE_URL + JWT_SECRET are strictly required.
# Email sends fall back to console + emailLog rows when RESEND_API_KEY is unset.

# ─── Database (required) ───────────────────────────────────────────────
# Production: Neon connection string (https://neon.tech)
# Local dev:  postgres on Postgres.app, port 54329 by convention
DATABASE_URL=postgresql://vladtayman@127.0.0.1:54329/commission_tracker

# ─── Auth (required) ───────────────────────────────────────────────────
# JWT signing secret. Generate with:  openssl rand -hex 32
# Each environment (dev/prod) should have its own value.
JWT_SECRET=

# ─── App URL (required for magic links + email links) ──────────────────
# The public URL where this app lives. Magic-link emails build their links
# from this. Local: http://localhost:3000  ·  Prod: https://app.traderfoundation.com
APP_URL=http://localhost:3000

# ─── Email (Resend — optional in dev, required in prod) ───────────────
# Without RESEND_API_KEY, sends fall back to console + emailLog rows with
# status='stubbed'. Sign up + verify your domain at https://resend.com.
RESEND_API_KEY=

# Optional email defaults — sensible TF defaults are used if blank.
EMAIL_FROM_ADDRESS=noreply@traderfoundation.com
EMAIL_FROM_NAME=Trader Foundation
EMAIL_REPLY_TO=ariana@traderfoundation.com

# ─── Cron auth (required for production scheduler) ────────────────────
# Vercel Cron sends Authorization: Bearer <CRON_SECRET> on each scheduled
# call. Generate with:  openssl rand -hex 32
CRON_SECRET=

# ─── Misc ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
